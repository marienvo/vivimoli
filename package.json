{
  "name": "vivimoli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "surge": "npm run build && surge dist/ vivimoli.marienvanoverbeek.nl"
  },
  "dependencies": {
    "bitecs": "0.4.0",
    "immer": "11.1.4",
    "pixi.js": "8.16.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xstate": "5.28.0",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.56.0",
    "@typescript-eslint/parser": "8.56.0",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.3",
    "eslint-plugin-boundaries": "5.4.0",
    "eslint-plugin-import": "2.32.0",
    "typescript":"5.9.3" ,
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
